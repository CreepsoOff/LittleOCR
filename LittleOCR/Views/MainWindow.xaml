<Window
    x:Class="LittleOCR.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:LittleOCR.ViewModels"
    xmlns:conv="clr-namespace:LittleOCR.Converters"
    Title="LittleOCR"
    Width="1100" Height="750"
    MinWidth="720" MinHeight="500"
    Background="{StaticResource AppBgBrush}"
    FontFamily="{StaticResource AppFont}"
    Foreground="{StaticResource AppTextBrush}"
    AllowDrop="True"
    Drop="OnWindowDrop"
    DragOver="OnWindowDragOver">

    <Window.Resources>
        <conv:BoolToVisibilityConverter        x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:InverseBoolConverter             x:Key="InvBool"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0 – Toolbar          -->
            <RowDefinition Height="Auto"/>  <!-- 1 – OCR progress bar -->
            <RowDefinition Height="*"/>     <!-- 2 – Main area        -->
            <RowDefinition Height="Auto"/>  <!-- 3 – Status bar       -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════
             ROW 0 – TOOLBAR
        ═══════════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <DockPanel LastChildFill="False">

                <!-- App name -->
                <TextBlock Text="LittleOCR"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource AppTextBrush}"
                           VerticalAlignment="Center"
                           Margin="4,0,20,0"
                           DockPanel.Dock="Left"/>

                <!-- Open image button -->
                <Button Content="📂  Ouvrir"
                        Command="{Binding OpenImageCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        ToolTip="Ouvrir une image (PNG, JPG, BMP, WebP)"
                        DockPanel.Dock="Left"
                        Margin="0,0,4,0"/>

                <!-- Copy-all shortcut in toolbar (only when OCR done) -->
                <Button Content="📋  Copier tout"
                        Command="{Binding CopyAllCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Visibility="{Binding HasOcrResult, Converter={StaticResource BoolToVis}}"
                        ToolTip="Copier tout le texte reconnu"
                        DockPanel.Dock="Left"
                        Margin="0,0,4,0"/>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════
             ROW 1 – INDETERMINATE PROGRESS BAR (visible only while OCR runs)
        ═══════════════════════════════════════════════════════════════════════ -->
        <ProgressBar Grid.Row="1"
                     IsIndeterminate="True"
                     Visibility="{Binding IsOcrRunning, Converter={StaticResource BoolToVis}}"/>

        <!-- ═══════════════════════════════════════════════════════════════════
             ROW 2 – MAIN CONTENT
        ═══════════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">

            <!-- ── EMPTY STATE (no image loaded) ─────────────────────────── -->
            <Border Background="{StaticResource AppBgBrush}"
                    Visibility="{Binding IsImageLoaded, Converter={StaticResource InvBoolToVis}}"
                    AllowDrop="True">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            MaxWidth="360">
                    <TextBlock Text="📷" FontSize="72"
                               HorizontalAlignment="Center"
                               Foreground="#FF444450"/>
                    <TextBlock Text="Glissez une image ici"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,6"/>
                    <TextBlock Text="ou utilisez le bouton Ouvrir dans la barre d'outils"
                               FontSize="13"
                               Foreground="{StaticResource AppTextMutedBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="PNG · JPG · BMP · WebP"
                               FontSize="11"
                               Foreground="#FF555560"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                    <Button Content="Ouvrir une image"
                            Command="{Binding OpenImageCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Center"
                            Margin="0,24,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── IMAGE VIEWER (image is loaded) ────────────────────────── -->
            <Grid Visibility="{Binding IsImageLoaded, Converter={StaticResource BoolToVis}}">

                <!-- Scrollable image area -->
                <ScrollViewer x:Name="ImageScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource AppBgBrush}"
                              PanningMode="Both">
                    <Grid x:Name="ImageGrid"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <!-- The displayed image -->
                        <Image x:Name="DisplayedImage"
                               Source="{Binding ImageSource}"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SizeChanged="OnImageSizeChanged"/>

                        <!-- OCR overlay canvas — exactly the same size as the Image control -->
                        <Canvas x:Name="OcrOverlayCanvas"
                                Visibility="{Binding IsOverlayVisible, Converter={StaticResource BoolToVis}}"
                                Background="Transparent"
                                IsHitTestVisible="True"
                                MouseLeftButtonDown="OnCanvasBackgroundClicked"/>
                    </Grid>
                </ScrollViewer>

                <!-- ── FLOATING OCR BUTTON (bottom-right) ──────────────── -->
                <Button x:Name="OcrButton"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,24,80"
                        Content="{Binding OcrButtonLabel}"
                        Command="{Binding RunOcrCommand}"
                        Style="{StaticResource OcrFloatingButtonStyle}"
                        ToolTip="Analyser le texte dans cette image (OCR)"/>

                <!-- ── ACTION BAR (bottom-center, appears after OCR) ──────── -->
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,18"
                        Visibility="{Binding HasOcrResult, Converter={StaticResource BoolToVis}}"
                        Background="{StaticResource AppSurface2Brush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10,7">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.35"
                                          BlurRadius="18" ShadowDepth="3"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Copier tout -->
                        <Button Content="📋  Copier tout"
                                Command="{Binding CopyAllCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Copier tout le texte reconnu dans le presse-papiers"
                                Margin="0,0,6,0"/>

                        <!-- Copier la sélection -->
                        <Button Content="✂  Copier la sélection"
                                Command="{Binding CopySelectionCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Copier uniquement les blocs de texte sélectionnés"
                                Margin="0,0,6,0"/>

                        <!-- Séparateur visuel -->
                        <Border Width="1" Background="{StaticResource AppBorderBrush}"
                                Margin="2,4"/>

                        <!-- Toggle overlay -->
                        <Button Command="{Binding ToggleOverlayCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Masquer / afficher les zones de texte"
                                Margin="6,0,0,0">
                            <Button.Content>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="🙈  Masquer l'OCR"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverlayVisible}" Value="False">
                                                    <Setter Property="Text" Value="👁  Afficher l'OCR"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Border>

            </Grid><!-- end image viewer grid -->
        </Grid><!-- end main content grid -->

        <!-- ═══════════════════════════════════════════════════════════════════
             ROW 3 – STATUS BAR
        ═══════════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,6"
                Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="✕"
                        Command="{Binding ClearStatusCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource AppTextMutedBrush}"
                        Padding="6,0"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        ToolTip="Fermer"/>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusLevel}"
                                             Value="{x:Static vm:StatusLevel.Warning}">
                                    <Setter Property="Foreground" Value="{StaticResource AppWarningBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusLevel}"
                                             Value="{x:Static vm:StatusLevel.Error}">
                                    <Setter Property="Foreground" Value="{StaticResource AppErrorBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </DockPanel>
        </Border>

    </Grid>
</Window>
